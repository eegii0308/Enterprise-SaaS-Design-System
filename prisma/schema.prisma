generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                     String                  @id @default(cuid())
  name                   String
  defaultCurrency        String                  @default("MNT") @map("default_currency")
  fiscalYearStartMonth   Int                     @default(1) @map("fiscal_year_start_month")
  createdAt              DateTime                @default(now()) @map("created_at")
  updatedAt              DateTime                @updatedAt @map("updated_at")
  auditLogs              AuditLog[]
  bankAccounts           BankAccount[]
  importBatches          ImportBatch[]
  importRows             ImportRow[]
  invitations            Invitation[]
  matchingRules          MatchingRule[]
  memberships            Membership[]
  reconciliationMatches  ReconciliationMatch[]
  reconciliationRuns     ReconciliationRun[]
  reports                Report[]
  roles                  Role[]
  transactionAdjustments TransactionAdjustment[]
  transactionNotes       TransactionReviewNote[]
  transactions           Transaction[]

  @@map("organizations")
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  passwordHash        String               @map("password_hash")
  fullName            String               @map("full_name")
  status              UserStatus           @default(ACTIVE)
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  memberships         Membership[]
  sentInvitations     Invitation[]
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

model Session {
  id           String     @id @default(cuid())
  userId       String     @map("user_id")
  membershipId String     @map("membership_id")
  expiresAt    DateTime   @map("expires_at")
  revokedAt    DateTime?  @map("revoked_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  membership   Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([membershipId])
  @@index([expiresAt])
  @@map("sessions")
}

model Membership {
  id             String           @id @default(cuid())
  organizationId String           @map("organization_id")
  userId         String           @map("user_id")
  roleId         String           @map("role_id")
  status         MembershipStatus @default(ACTIVE)
  invitedAt      DateTime?        @map("invited_at")
  joinedAt       DateTime?        @map("joined_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           Role             @relation(fields: [organizationId, roleId], references: [organizationId, id], onDelete: Restrict, onUpdate: Cascade)
  sessions       Session[]
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitations    Invitation[]

  @@unique([organizationId, userId])
  @@unique([organizationId, id])
  @@index([userId])
  @@map("memberships")
}

model Role {
  id             String           @id @default(cuid())
  organizationId String           @map("organization_id")
  name           SystemRoleName
  description    String
  isSystemRole   Boolean          @default(true) @map("is_system_role")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  memberships    Membership[]
  permissions    RolePermission[]
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitations    Invitation[]

  @@unique([organizationId, name])
  @@unique([organizationId, id])
  @@map("roles")
}

model RolePermission {
  id         String   @id @default(cuid())
  roleId     String   @map("role_id")
  permission String
  createdAt  DateTime @default(now()) @map("created_at")
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permission])
  @@map("role_permissions")
}

model Invitation {
  id              String           @id @default(cuid())
  organizationId  String           @map("organization_id")
  email           String
  roleId          String           @map("role_id")
  invitedByUserId String           @map("invited_by_user_id")
  membershipId    String?          @map("membership_id")
  tokenHash       String           @unique @map("token_hash")
  status          InvitationStatus @default(PENDING)
  expiresAt       DateTime         @map("expires_at")
  acceptedAt      DateTime?        @map("accepted_at")
  revokedAt       DateTime?        @map("revoked_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role            Role             @relation(fields: [organizationId, roleId], references: [organizationId, id], onDelete: Restrict, onUpdate: Cascade)
  invitedBy       User             @relation(fields: [invitedByUserId], references: [id])
  membership      Membership?      @relation(fields: [organizationId, membershipId], references: [organizationId, id], onDelete: NoAction, onUpdate: Cascade)

  // A partial unique index on (organization_id, email) WHERE status = 'PENDING'
  // also exists (see the invitations migration) to prevent duplicate concurrent
  // pending invitations for the same email; Prisma's schema DSL cannot express
  // a WHERE-qualified unique index, so it is not declared here (same pattern
  // already used by BankAccount above).
  @@index([organizationId, status])
  @@index([email])
  @@map("invitations")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model BankAccount {
  id                  String              @id @default(cuid())
  organizationId      String              @map("organization_id")
  name                String
  bankName            String              @map("bank_name")
  maskedAccountNumber String              @map("masked_account_number")
  currency            String
  status              String              @default("active")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")
  organization        Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transactions        Transaction[]
  reconciliationRuns  ReconciliationRun[]

  @@unique([organizationId, id])
  // A partial unique index on (organization_id, bank_name, masked_account_number)
  // WHERE status = 'active' also exists (added in migration
  // 20260710050000_phase_7d_bank_account_management) to prevent duplicate
  // active accounts; Prisma's schema DSL cannot express a WHERE-qualified
  // unique index, so it is not declared here.
  @@index([organizationId, status])
  @@map("bank_accounts")
}

model ImportBatch {
  id              String        @id @default(cuid())
  organizationId  String        @map("organization_id")
  sourceType      SourceType    @map("source_type")
  fileName        String        @map("file_name")
  fileSize        Int           @map("file_size")
  fileStorageKey  String        @map("file_storage_key")
  fileHash        String        @map("file_hash")
  status          ImportStatus  @default(PENDING)
  totalRows       Int           @default(0) @map("total_rows")
  validRows       Int           @default(0) @map("valid_rows")
  errorRows       Int           @default(0) @map("error_rows")
  duplicateRows   Int           @default(0) @map("duplicate_rows")
  columnMapping   Json?         @map("column_mapping")
  processingError String?       @map("processing_error")
  createdBy       String        @map("created_by")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  completedAt     DateTime?     @map("completed_at")
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  rows            ImportRow[]
  transactions    Transaction[]

  @@unique([organizationId, fileHash])
  @@unique([organizationId, id])
  @@index([organizationId, createdAt])
  @@index([organizationId, status])
  @@map("import_batches")
}

model ImportRow {
  id                   String          @id @default(cuid())
  organizationId       String          @map("organization_id")
  importBatchId        String          @map("import_batch_id")
  rowNumber            Int             @map("row_number")
  rawData              Json            @map("raw_data")
  normalizedData       Json?           @map("normalized_data")
  rowHash              String          @map("row_hash")
  validationStatus     ImportRowStatus @default(PENDING) @map("validation_status")
  errorMessages        Json?           @map("error_messages")
  // Flattened, lowercase-insensitive-searchable text built from rawData's
  // values and errorMessages (see buildImportRowSearchText in csv-core.ts).
  // CSV column headers vary per uploaded file, so Prisma's typed Json filters
  // (which require a fixed `path`) can't search "any key" in rawData; this
  // plain-text column lets the results viewer use the same
  // `contains`/`mode: "insensitive"` search pattern already used elsewhere
  // (e.g. Transaction.description on the transactions page).
  searchText           String          @default("") @map("search_text")
  createdTransactionId String?         @unique @map("created_transaction_id")
  createdAt            DateTime        @default(now()) @map("created_at")
  createdTransaction   Transaction?    @relation("CreatedTransaction", fields: [organizationId, createdTransactionId], references: [organizationId, id], onDelete: NoAction, onUpdate: Cascade)
  importBatch          ImportBatch     @relation(fields: [organizationId, importBatchId], references: [organizationId, id], onDelete: Cascade, onUpdate: Cascade)
  organization         Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, importBatchId, rowNumber])
  @@unique([organizationId, rowHash])
  @@unique([organizationId, createdTransactionId])
  @@index([organizationId, importBatchId, validationStatus])
  @@map("import_rows")
}

model Transaction {
  id                  String                  @id @default(cuid())
  organizationId      String                  @map("organization_id")
  importBatchId       String?                 @map("import_batch_id")
  sourceType          SourceType              @map("source_type")
  bankAccountId       String?                 @map("bank_account_id")
  transactionDate     DateTime                @map("transaction_date")
  description         String
  vendor              String?
  reference           String?
  debitAmount         Decimal                 @default(0) @map("debit_amount") @db.Decimal(18, 2)
  creditAmount        Decimal                 @default(0) @map("credit_amount") @db.Decimal(18, 2)
  amount              Decimal                 @db.Decimal(18, 2)
  currency            String
  status              TransactionStatus       @default(UNMATCHED)
  externalFingerprint String                  @map("external_fingerprint")
  exceptionReason     String?                 @map("exception_reason")
  exceptionMarkedBy   String?                 @map("exception_marked_by")
  exceptionMarkedAt   DateTime?               @map("exception_marked_at")
  exceptionClearedBy  String?                 @map("exception_cleared_by")
  exceptionClearedAt  DateTime?               @map("exception_cleared_at")
  createdAt           DateTime                @default(now()) @map("created_at")
  updatedAt           DateTime                @updatedAt @map("updated_at")
  sourceRow           ImportRow?              @relation("CreatedTransaction")
  bankMatches         ReconciliationMatch[]   @relation("BankTransaction")
  ledgerMatches       ReconciliationMatch[]   @relation("LedgerTransaction")
  adjustments         TransactionAdjustment[]
  notes               TransactionReviewNote[]
  bankAccount         BankAccount?            @relation(fields: [organizationId, bankAccountId], references: [organizationId, id], onDelete: NoAction, onUpdate: Cascade)
  importBatch         ImportBatch?            @relation(fields: [organizationId, importBatchId], references: [organizationId, id], onDelete: NoAction, onUpdate: Cascade)
  organization        Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, externalFingerprint])
  @@unique([organizationId, id])
  @@index([organizationId, status])
  @@index([organizationId, sourceType, status, transactionDate])
  @@index([organizationId, importBatchId])
  @@index([organizationId, bankAccountId, transactionDate])
  @@map("transactions")
}

model TransactionReviewNote {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  transactionId  String       @map("transaction_id")
  note           String
  createdBy      String       @map("created_by")
  createdAt      DateTime     @default(now()) @map("created_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transaction    Transaction  @relation(fields: [organizationId, transactionId], references: [organizationId, id], onDelete: Cascade, onUpdate: Cascade)

  @@index([organizationId, transactionId])
  @@map("transaction_review_notes")
}

model TransactionAdjustment {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  transactionId  String       @map("transaction_id")
  fieldName      String       @map("field_name")
  oldValue       String       @map("old_value")
  newValue       String       @map("new_value")
  reason         String
  createdBy      String       @map("created_by")
  createdAt      DateTime     @default(now()) @map("created_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transaction    Transaction  @relation(fields: [organizationId, transactionId], references: [organizationId, id], onDelete: Cascade, onUpdate: Cascade)

  @@map("transaction_adjustments")
}

model ReconciliationRun {
  id             String                  @id @default(cuid())
  organizationId String                  @map("organization_id")
  bankAccountId  String                  @map("bank_account_id")
  name           String
  periodStart    DateTime                @map("period_start")
  periodEnd      DateTime                @map("period_end")
  status         ReconciliationRunStatus @default(DRAFT)
  createdBy      String                  @map("created_by")
  approvedBy     String?                 @map("approved_by")
  approvedAt     DateTime?               @map("approved_at")
  reopenedBy     String?                 @map("reopened_by")
  reopenedAt     DateTime?               @map("reopened_at")
  createdAt      DateTime                @default(now()) @map("created_at")
  completedAt    DateTime?               @map("completed_at")
  matches        ReconciliationMatch[]
  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bankAccount    BankAccount             @relation(fields: [organizationId, bankAccountId], references: [organizationId, id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([organizationId, id])
  @@index([organizationId, status])
  @@index([organizationId, bankAccountId, status], map: "reconciliation_runs_organization_bank_account_status_idx")
  @@map("reconciliation_runs")
}

model ReconciliationMatch {
  id                   String                    @id @default(cuid())
  organizationId       String                    @map("organization_id")
  reconciliationRunId  String                    @map("reconciliation_run_id")
  bankTransactionId    String                    @map("bank_transaction_id")
  ledgerTransactionId  String                    @map("ledger_transaction_id")
  matchType            ReconciliationMatchType   @map("match_type")
  confidenceScore      Decimal?                  @map("confidence_score") @db.Decimal(5, 2)
  status               ReconciliationMatchStatus @default(PROPOSED)
  createdBy            String                    @map("created_by")
  removedBy            String?                   @map("removed_by")
  removedAt            DateTime?                 @map("removed_at")
  createdAt            DateTime                  @default(now()) @map("created_at")
  correctedFromMatchId String?                   @map("corrected_from_match_id")
  correctionReason     String?                   @map("correction_reason")
  rejectedBy           String?                   @map("rejected_by")
  rejectedAt           DateTime?                 @map("rejected_at")
  rejectionReason      String?                   @map("rejection_reason")
  bankTransaction      Transaction               @relation("BankTransaction", fields: [organizationId, bankTransactionId], references: [organizationId, id], onDelete: Restrict, onUpdate: Cascade)
  ledgerTransaction    Transaction               @relation("LedgerTransaction", fields: [organizationId, ledgerTransactionId], references: [organizationId, id], onDelete: Restrict, onUpdate: Cascade)
  organization         Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reconciliationRun    ReconciliationRun         @relation(fields: [organizationId, reconciliationRunId], references: [organizationId, id], onDelete: Cascade, onUpdate: Cascade)
  correctedFromMatch   ReconciliationMatch?      @relation("MatchCorrection", fields: [organizationId, correctedFromMatchId], references: [organizationId, id], onDelete: NoAction, onUpdate: Cascade)
  correctedByMatches   ReconciliationMatch[]     @relation("MatchCorrection")

  @@unique([organizationId, id])
  @@index([organizationId, reconciliationRunId])
  @@map("reconciliation_matches")
}

model MatchingRule {
  id                 String             @id @default(cuid())
  organizationId     String             @map("organization_id")
  name               String
  description        String?
  vendorPattern      String?            @map("vendor_pattern")
  descriptionPattern String?            @map("description_pattern")
  referencePattern   String?            @map("reference_pattern")
  amountTolerance    Decimal            @default(0) @map("amount_tolerance") @db.Decimal(18, 2)
  dateToleranceDays  Int                @default(0) @map("date_tolerance_days")
  priority           Int                @default(100)
  status             MatchingRuleStatus @default(DRAFT)
  createdBy          String             @map("created_by")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  organization       Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@map("matching_rules")
}

model Report {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  reportType     ReportType   @map("report_type")
  periodStart    DateTime     @map("period_start")
  periodEnd      DateTime     @map("period_end")
  status         ReportStatus @default(PENDING)
  fileStorageKey String?      @map("file_storage_key")
  expiresAt      DateTime?    @map("expires_at")
  createdBy      String       @map("created_by")
  createdAt      DateTime     @default(now()) @map("created_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, reportType])
  @@index([organizationId, status])
  @@map("reports")
}

model AuditLog {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  actorUserId    String?      @map("actor_user_id")
  action         String
  resourceType   String       @map("resource_type")
  resourceId     String?      @map("resource_id")
  metadata       Json?
  ipAddress      String?      @map("ip_address")
  createdAt      DateTime     @default(now()) @map("created_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@map("audit_logs")
}

enum UserStatus {
  ACTIVE
  DISABLED
  PENDING
}

enum MembershipStatus {
  ACTIVE
  DISABLED
  INVITED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum SystemRoleName {
  ADMIN
  FINANCE_MANAGER
  ACCOUNTANT
  AUDITOR
  VIEWER
}

enum SourceType {
  BANK
  LEDGER
}

enum ImportStatus {
  PENDING
  UPLOADED
  PROCESSING
  COMPLETED
  COMPLETED_WITH_ERRORS
  FAILED
}

enum ImportRowStatus {
  PENDING
  VALID
  DUPLICATE
  INVALID
  PROCESSED
}

enum TransactionStatus {
  UNMATCHED
  MATCHED
  PENDING_REVIEW
  EXCEPTION
}

enum ReconciliationRunStatus {
  DRAFT
  IN_PROGRESS
  READY_FOR_REVIEW
  APPROVED
  REOPENED
}

enum ReconciliationMatchType {
  MANUAL
  RULE
}

enum ReconciliationMatchStatus {
  PROPOSED
  CONFIRMED
  REJECTED
  REMOVED
}

enum MatchingRuleStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

enum ReportType {
  RECONCILIATION_SUMMARY
  EXCEPTION_LIST
  UNMATCHED_TRANSACTIONS
}

enum ReportStatus {
  PENDING
  READY
  FAILED
}
