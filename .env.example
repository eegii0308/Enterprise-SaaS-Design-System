# Required for Prisma database access.
# Use a local development database here; set a managed PostgreSQL URL in production.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/e_reconcile_mn?schema=public"

# Required for signing the application session cookie.
# Replace with a unique random value of at least 32 characters.
AUTH_SESSION_SECRET="replace-with-a-unique-random-secret-at-least-32-characters"
