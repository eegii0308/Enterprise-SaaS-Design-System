# Required for Prisma database access.
# Use a local development database here; set a managed PostgreSQL URL in production.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/e_reconcile_mn?schema=public"

# Required for signing the application session cookie.
# Replace with a unique random value of at least 32 characters.
AUTH_SESSION_SECRET="replace-with-a-unique-random-secret-at-least-32-characters"

# Required for building links (e.g. invitation accept links) that point back
# at this app. No trailing slash.
APP_BASE_URL="http://localhost:3000"

# Required for sending invitation emails via Resend (https://resend.com).
RESEND_API_KEY="replace-with-your-resend-api-key"
EMAIL_FROM="E-Reconcile MN <no-reply@yourdomain.com>"

# All optional -- rate limiting (lib/rate-limit/) has safe hardcoded defaults
# for every one of these, so none must be set. Override only to tune limits
# per environment. See lib/rate-limit/config.ts for the defaults.
# RATE_LIMIT_LOGIN_IP_MAX=10
# RATE_LIMIT_LOGIN_IP_WINDOW_SECONDS=60
# RATE_LIMIT_LOGIN_ACCOUNT_MAX=5
# RATE_LIMIT_LOGIN_ACCOUNT_WINDOW_SECONDS=900
# RATE_LIMIT_REGISTER_IP_MAX=5
# RATE_LIMIT_REGISTER_IP_WINDOW_SECONDS=3600
# RATE_LIMIT_FORGOT_PW_IP_MAX=10
# RATE_LIMIT_FORGOT_PW_IP_WINDOW_SECONDS=3600
# RATE_LIMIT_FORGOT_PW_ACCOUNT_MAX=3
# RATE_LIMIT_FORGOT_PW_ACCOUNT_WINDOW_SECONDS=3600
# RATE_LIMIT_IMPORT_USER_MAX=5
# RATE_LIMIT_IMPORT_USER_WINDOW_SECONDS=60
# RATE_LIMIT_IMPORT_ORG_MAX=50
# RATE_LIMIT_IMPORT_ORG_WINDOW_SECONDS=3600
